# ===== Эрхэт тохиргоо =====
ERKHET_URL=https://erkhet.bto.mn
ERKHET_USERNAME=
ERKHET_PASSWORD=
# Компанийн ID (URL дотор харагддаг тоо, жишээ нь 9514593312)
ERKHET_COMPANY_ID=9514593312

# ===== Тайлан тохиргоо =====
# Ямар тайлан татах вэ? Дараахаас сонгоно:
#   main_journal        = Ерөнхий журнал
#   fund                = Мөнгөн хөрөнгө
#   debt                = Авлага өглөг
#   inventory_cost      = Бараа материал /Өртгөөр/
#   sale_item           = Борлуулалт /Бараагаар/
#   sale_cost           = Борлуулалт /Өртгөөр/
#   inventory_daily     = Бараа материал /Баримтаар/
#   inventory_census    = Бараа материал тооллого
#   fixed_asset         = Үндсэн хөрөнгө
#   debt_finish         = Тооцоо хаагдах төлөв
#   inventory_remainder = Барааны хязгаарт үлдэгдэл
#   inventory_price     = Бараа материал /Үнээр/
#   inventory_shipper   = Бараа нийлүүлэлтийн тооцоо
#   inventory_profit    = Барааны ашгийн тайлан
#   sale_cost_period    = Борлуулалт /Өртгөөр/ - Үе шат
#   subsys              = Дэд системийн тайлан
#   balance             = Баланс (тайлангийн форм)
#   result              = Үр дүнгийн тайлан (тайлангийн форм)
REPORT_TYPE=main_journal

# Тайлангийн хугацаа: today, yesterday, this_month, last_month
REPORT_PERIOD=yesterday

# ===== Татсан файл хадгалах =====
DOWNLOAD_DIR=./downloads

# ===== Мэдэгдэл (заавал биш) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Facebook Messenger (заавал биш) =====
# Милко, Алтанжолоо тайланг Messenger group руу автомат илгээнэ
MESSENGER_ENABLED=false
FB_EMAIL=
FB_PASSWORD=
MESSENGER_GROUP_MILKO=
MESSENGER_GROUP_ALTANJOLUU=
MESSENGER_MESSAGE=Өглөөний мэнд. Өчигдрийн мэдээний тайлан явууллаа.Өдрийг сайхан өнгөрүүлээрэй. Бүтэн-Оргил Agent

# ===== Scheduler =====
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0
